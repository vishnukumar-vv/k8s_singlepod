pipeline {
    agent { label 'k8s_agent' }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main', url: 'https://github.com/vishnukumar-vv/k8s_singlepod.git'
            }
        }

        stage('Check Cluster') {
            steps {
                sh 'kubectl get nodes'
            }
        }

        stage('Validate YAML') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh 'kubectl apply --dry-run=client -f pod.yaml'
                }
            }
        }

        stage('Deploy Pod') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh 'kubectl apply -f pod.yaml'
                    sh 'kubectl wait --for=condition=ready pod -l app=nginx --timeout=60s'
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                sh 'kubectl get pods -o wide'
            }
        }
    }
}
