pipeline {
    agent { label 'k8s_agent' }

    stages {

        stage('Check Cluster') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh 'kubectl get nodes'
                }
            }
        }

        stage('Deploy Multi Pod') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh 'kubectl apply -f multi-pod.yaml'
                    sh 'kubectl wait --for=condition=ready pod/multi-container-logs -n pd --timeout=60s'
                }
            }
        }

        stage('Verify Pod') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh 'kubectl get pods -n pd'
                }
            }
        }

        stage('Check Logs') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh 'kubectl logs multi-container-logs -c log-sidecar -n pd --tail=5'
                }
            }
        }
    }
}
